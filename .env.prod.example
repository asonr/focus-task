FOCUS_TASK_SECRET_KEY=replace-with-a-long-random-secret
FOCUS_TASK_TOKEN_EXPIRE_MINUTES=10080
FOCUS_TASK_PASSWORD_MIN_LENGTH=8

FOCUS_TASK_API_PORT=8765
FOCUS_TASK_WEB_PORT=8080
FOCUS_TASK_CORS_ORIGINS=

# Replace OWNER/REPO with your GitHub repository path, for example:
# ghcr.io/awei/focus-task/focus-task-api:latest
FOCUS_TASK_API_IMAGE=ghcr.io/OWNER/REPO/focus-task-api:latest
FOCUS_TASK_WEB_IMAGE=ghcr.io/OWNER/REPO/focus-task-web:latest
