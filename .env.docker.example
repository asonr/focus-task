FOCUS_TASK_SECRET_KEY=replace-with-a-long-random-secret
FOCUS_TASK_TOKEN_EXPIRE_MINUTES=10080
FOCUS_TASK_PASSWORD_MIN_LENGTH=8
FOCUS_TASK_BOOTSTRAP_ADMIN_USERNAME=admin
FOCUS_TASK_BOOTSTRAP_ADMIN_PASSWORD=admin123

# API exposed to the host. Tauri desktop can connect to http://SERVER_IP:8765
FOCUS_TASK_API_PORT=8765

# Web UI exposed to the host.
FOCUS_TASK_WEB_PORT=8080

# Add browser origins only when the API is called directly from another origin.
# Example: FOCUS_TASK_CORS_ORIGINS=http://localhost:8080,https://tasks.example.com
FOCUS_TASK_CORS_ORIGINS=
